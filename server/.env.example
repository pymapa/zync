# Server Environment Variables
# Copy to .env.local and fill in your secrets

# Server
PORT=3001
NODE_ENV=development

# Strava API - Get from https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret

# Strava Webhook - Custom verification token for webhook subscription
# Set this to any string (e.g., "STRAVA") when creating the webhook subscription
STRAVA_WEBHOOK_VERIFY_TOKEN=STRAVA

# Strava Webhook Subscription ID (optional) - For additional security validation
# After creating a webhook subscription, Strava returns a subscription_id
# Setting this validates that incoming webhooks match our subscription
# STRAVA_WEBHOOK_SUBSCRIPTION_ID=123456

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Cookie secret - Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=your_secure_random_string_at_least_32_characters
