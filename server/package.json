{
  "name": "zync-server",
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate:types": "openapi-typescript ./src/openapi.yaml -o ./src/types/api.generated.ts",
    "seed": "ts-node src/scripts/seed.ts",
    "db:shell": "ts-node src/scripts/db-shell.ts",
    "db:migrate": "ts-node src/scripts/migrate.ts"
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "axios": "^1.6.7",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.19.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "leaflet": "^1.9.4",
    "pg": "^8.20.0",
    "polyline-encoded": "^0.0.9",
    "react-leaflet": "^5.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.19",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.17",
    "openapi-typescript": "^7.10.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.17"
  }
}
